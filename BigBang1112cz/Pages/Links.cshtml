@page
@model LinksModel
@{
    ViewData["Title"] = "Links";
}

<div class="page-hero">
    <h1>Links</h1>
    <p>Find me across the web.</p>
</div>

<div class="page-content">
    <ul class="link-list">
        @foreach (var link in LinksModel.Links)
        {
            <li>
                <a class="link-item" href="@link.Url" target="_blank" rel="noopener">
                    <div class="link-item-label">@link.Label</div>
                    <div class="link-item-url">@(new Uri(link.Url).Host + new Uri(link.Url).AbsolutePath.TrimEnd('/'))</div>
                </a>
            </li>
        }
    </ul>
</div>
